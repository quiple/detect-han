{
  "name": "@quiple/detect-han",
  "version": "0.1.0",
  "description": "Detect region-exclusive Korean, Chinese, and Japanese Han characters from Unihan data",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "browser": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/quiple/detect-han.git"
  },
  "bugs": {
    "url": "https://github.com/quiple/detect-han/issues"
  },
  "homepage": "https://github.com/quiple/detect-han#readme",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "THIRD_PARTY_NOTICES.md"
  ],
  "scripts": {
    "build": "tsup && tsc -p tsconfig.build.json",
    "benchmark": "npm run build && node benchmark/benchmark.mjs",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck && npm test && npm run build",
    "prepublishOnly": "npm run check",
    "update:unihan": "node scripts/update-unihan.mjs && npm run check"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "han",
    "hanja",
    "kanji",
    "unihan",
    "unicode",
    "chinese",
    "japanese",
    "korean"
  ],
  "license": "MIT",
  "devDependencies": {
    "fflate": "^0.8.3",
    "tsup": "^8.5.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
